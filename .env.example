# ── Agent Messenger Configuration ──
# Copy this file to .env and fill in values before running docker-compose.

# Required: JWT secret for token signing (generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
MESSENGER_JWT_SECRET=change-me-to-a-real-secret

# JWT token expiry (seconds)
MESSENGER_JWT_ACCESS_EXPIRY=900
MESSENGER_JWT_REFRESH_EXPIRY=604800

# Enable auth (set to "true" in production)
MESSENGER_AUTH_ENABLED=false

# Server port
MESSENGER_PORT=8096

# CORS origins (comma-separated, or * for all)
MESSENGER_CORS_ORIGINS=*
